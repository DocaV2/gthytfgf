local function DocaGetGuiParent()
  if RunService:IsStudio() then
    return Player:WaitForChild("PlayerGui")
  end

  local okHui, hui = pcall(function()
    if gethui then
      return gethui()
    end
  end)
  if okHui and hui then
    return hui
  end

  local CoreGui = game:GetService("CoreGui")
  local okClone, clonedCoreGui = pcall(function()
    if cloneref then
      return cloneref(CoreGui)
    end
  end)

  if okClone and clonedCoreGui then
    return clonedCoreGui
  end

  return CoreGui
end

local function DocaCloseOldLibrary()
  local Parent = DocaGetGuiParent()

  for _, GuiName in ipairs({DOCA_MAIN_GUI_NAME, DOCA_OPEN_GUI_NAME}) do
    local OldGui = Parent:FindFirstChild(GuiName)
    if OldGui then
      pcall(function()
        OldGui:Destroy()
      end)
    end
  end

  pcall(function()
    if _G.DocaV1_MainGui and _G.DocaV1_MainGui.Parent then
      _G.DocaV1_MainGui:Destroy()
    end
    if _G.DocaV1_OpenGui and _G.DocaV1_OpenGui.Parent then
      _G.DocaV1_OpenGui:Destroy()
    end
  end)
end

