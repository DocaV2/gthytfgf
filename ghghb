                    DocaUpdateMusicStatus("Speed updated")
                end
            })

            aw.MusicPlayer:AddToggle({
                Title = "Loop Music",
                Content = "Repeat the sound automatically.",
                Default = true,
                Callback = function(Value)
                    DocaMusicLooped = Value == true
                    DocaApplyMusicSettings()
                    DocaUpdateMusicStatus("Loop updated")
                end
            })

            aw.MusicPlayer:AddToggle({
                Title = "Play / Pause",
                Content = "Toggle local music.",
                Default = false,
                Callback = function(Value)
                    if Value then
                        DocaPlayMusic()
                    else
                        DocaPauseMusic()
                    end
                end
            })

            aw.MusicPlayer:AddButton({
                Title = "Stop Music",
                Content = "Stops and resets the current sound.",
                Icon = au.Mouse,
                Callback = function()
                    DocaStopMusic()
                end
            })
        end

        if aw and aw.UserMusic then
            aw.UserMusic:AddInput({
                Title = "Favorite Slot 1",
                Content = "Save a quick sound id.",
                Default = "",
                Callback = function(Value)
                    DocaFavoriteIds.Slot1 = tostring(Value or "")
                end
            })

            aw.UserMusic:AddInput({
                Title = "Favorite Slot 2",
                Content = "Save a quick sound id.",
                Default = "",
                Callback = function(Value)
                    DocaFavoriteIds.Slot2 = tostring(Value or "")
                end
            })

            aw.UserMusic:AddInput({
                Title = "Favorite Slot 3",
                Content = "Save a quick sound id.",
