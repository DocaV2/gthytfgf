  local function SetWindowVisible(State)
    if WindowAnimating or Speed_Library:IsUnloaded() then return end
    WindowHidden = not State
    WindowAnimating = true

    if State then
      DropShadowHolder.Visible = true
      Open_Close.Visible = false
      DropShadowHolder.Position = GetTopHiddenPosition()
      Main.Size = UDim2.new(0, math.floor((FinalWindowSize.X.Offset > 0 and FinalWindowSize.X.Offset or Main.AbsoluteSize.X) * 0.94), 0, math.floor((FinalWindowSize.Y.Offset > 0 and FinalWindowSize.Y.Offset or Main.AbsoluteSize.Y) * 0.94))
      DropShadow.Size = Main.Size
      Main.BackgroundTransparency = 1
      DropShadow.ImageTransparency = 1

      TweenService:Create(DropShadowHolder, TweenInfo.new(0.46, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = WindowOpenPosition
      }):Play()
      TweenService:Create(Main, TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Size = FinalWindowSize,
        BackgroundTransparency = 0.05
      }):Play()
      TweenService:Create(DropShadow, TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Size = FinalWindowSize,
        ImageTransparency = 0.42
      }):Play()

      task.delay(0.48, function()
        WindowAnimating = false
      end)
    else
      Open_Close.Visible = true

      TweenService:Create(DropShadowHolder, TweenInfo.new(0.34, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = GetTopHiddenPosition()
      }):Play()
      TweenService:Create(Main, TweenInfo.new(0.30, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        BackgroundTransparency = 1
      }):Play()
      TweenService:Create(DropShadow, TweenInfo.new(0.30, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        ImageTransparency = 1
      }):Play()

      task.delay(0.34, function()
        if WindowHidden then
          DropShadowHolder.Visible = false
          DropShadowHolder.Position = WindowOpenPosition
          Main.Size = FinalWindowSize
          DropShadow.Size = FinalWindowSize
          Main.BackgroundTransparency = 0.05
          DropShadow.ImageTransparency = 0.42
        end
        WindowAnimating = false
      end)
    end
  end

