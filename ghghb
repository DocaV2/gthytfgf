    --// No server dependency. Wrapped safely so the library always opens.
    pcall(function()
        local AdminNames = {
            ["renskuiiiiii"] = true
        }

        local function AdminLower(v)
            return string.lower(tostring(v or ""))
        end

        local function IsDocaAdmin(plr)
            if not plr then return false end
            return AdminNames[AdminLower(plr.Name)] == true or AdminNames[AdminLower(plr.DisplayName)] == true
        end

        local function AdminPlayerList()
            local list = {}
            for _, plr in ipairs(a:GetPlayers()) do
                if plr ~= b then
                    table.insert(list, tostring(plr.DisplayName) .. " [" .. tostring(plr.Name) .. "]")
                end
            end
            table.sort(list)
            return list
        end

        local function FindAdminPlayer(text)
            text = tostring(text or "")
            local low = AdminLower(text)
            for _, plr in ipairs(a:GetPlayers()) do
                local shown = tostring(plr.DisplayName) .. " [" .. tostring(plr.Name) .. "]"
                if text == shown or low == AdminLower(plr.Name) or low == AdminLower(plr.DisplayName) or text == tostring(plr.UserId) then
                    return plr
                end
            end
            return nil
        end

        local function AdminNotify(msg)
            pcall(function()
                as:SetNotification({"Admin", "", tostring(msg or ""), nil, 0.35, 2.5})
            end)
        end

        local function SendAdminChat(msg)
            msg = tostring(msg or "")
            if msg == "" then return end

            local sent = false
            pcall(function()
                local TextChatService = game:GetService("TextChatService")
                local channels = TextChatService:FindFirstChild("TextChannels")
                local general = channels and channels:FindFirstChild("RBXGeneral")
                if general then
                    general:SendAsync(msg)
                    sent = true
                end
            end)

            if not sent then
                pcall(function()
                    local chatEvents = e:FindFirstChild("DefaultChatSystemChatEvents")
                    local say = chatEvents and chatEvents:FindFirstChild("SayMessageRequest")
                    if say then
                        say:FireServer(msg, "All")
                    end
                end)
            end
        end

        local function DoLocalAdminAction(action, target, reason, chatText)
            action = tostring(action or "Chat")
            reason = tostring(reason or "No reason")
            chatText = tostring(chatText or "")

            if action == "Chat" then
                local targetName = target and (tostring(target.DisplayName) .. " [" .. tostring(target.Name) .. "]") or "Unknown"
                local finalMessage = chatText ~= "" and chatText or reason
                SendAdminChat("[Doca Admin -> " .. targetName .. "] " .. finalMessage)
                AdminNotify("Chat sent")
                return
            end

            -- Client can only rebirth/kick the local player unless your game has a server-side system.
            if target == b then
                if action == "Rebirths" then
                    pcall(function()
                        e.rEvents.rebirthRemote:InvokeServer("rebirthRequest")
                    end)
                    AdminNotify("Rebirth used")
                elseif action == "Kick" then
                    b:Kick("Doca Admin | " .. reason)
                end
            else
                SendAdminChat("[Doca Admin] " .. action .. " -> " .. tostring(target and target.Name or "Unknown") .. " | " .. reason)
                AdminNotify("Command sent in chat")
            end
        end

