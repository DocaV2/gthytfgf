        local function CountLines(Text)
          Text = tostring(Text or "")
          local Lines = 1
          for _ in string.gmatch(Text, "\n") do
            Lines = Lines + 1
          end
          return Lines
        end

        local function UpdateParagraphSize()
          local Width = math.max(ParagraphContent.AbsoluteSize.X, 1)
          local WrapLines = math.max(1, math.ceil(ParagraphContent.TextBounds.X / Width))
          local NewLines = CountLines(ParagraphContent.Text)
          local LineCount = math.max(NewLines, WrapLines)
          local LineHeight = ContentTextSize + 3
          local ContentTop = HideTitle and 8 or 23
          local BottomPadding = HideTitle and 10 or 12

          ParagraphContent.Size = UDim2.new(1, -16, 0, math.max(LineHeight, LineHeight * LineCount))
          Paragraph.Size = UDim2.new(1, 0, 0, ContentTop + ParagraphContent.Size.Y.Offset + BottomPadding)
          ParagraphContent.TextWrapped = true

          UpdateSizeSection()
        end

        UpdateParagraphSize()

        ParagraphContent:GetPropertyChangedSignal("AbsoluteSize"):Connect(UpdateParagraphSize)

