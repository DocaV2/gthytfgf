    local function BuildRingAura(Position)
        CleanRingAura()
        _G.showDeathRing = true

        local Theme = GetTheme()
        local Folder = Instance.new("Folder")
        Folder.Name = "DeathRingVisualizer"
        Folder.Parent = workspace
        _G.deathRingFolder = Folder
        _G.ringParticles = {}

        local Count = math.clamp(tonumber(_G.deathRingOrbs) or 13, 6, 32)
        local Size = math.clamp(tonumber(_G.deathRingSize) or 1.7, 0.5, 6)

        for Index = 1, Count do
            local Angle = Index / Count * math.pi * 2
            local Orb = Instance.new("Part")
            Orb.Name = "DocaRingOrb"
            Orb.Anchored = true
            Orb.CanCollide = false
            Orb.CanTouch = false
            Orb.CanQuery = false
            Orb.Shape = Enum.PartType.Ball
            Orb.Material = Enum.Material.Neon
            Orb.Size = Vector3.new(Size, Size, Size)
            Orb.Transparency = 0.1

            if _G.ringTheme == "Rainbow" then
                Orb.Color = GetRainbowColor(Index / Count)
            else
                Orb.Color = Theme.c1:Lerp(Theme.c2, (math.sin(Angle) + 1) / 2)
            end

            Orb.Parent = Folder

            local Attachment0 = Instance.new("Attachment")
            Attachment0.Position = Vector3.new(0, Size / 2, 0)
            Attachment0.Parent = Orb

            local Attachment1 = Instance.new("Attachment")
            Attachment1.Position = Vector3.new(0, -Size / 2, 0)
            Attachment1.Parent = Orb

            local Trail = Instance.new("Trail")
            Trail.Attachment0 = Attachment0
            Trail.Attachment1 = Attachment1
            Trail.Color = ColorSequence.new(Orb.Color, Theme.dark)
            Trail.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0.08),
                NumberSequenceKeypoint.new(1, 0.65)
            })
            Trail.Lifetime = 0.22
            Trail.MaxLength = math.max(3, _G.deathRingRange * 0.22)
            Trail.FaceCamera = true
            Trail.Parent = Orb

            local Particle = Instance.new("ParticleEmitter")
            Particle.Name = "DocaRingSmoke"
            Particle.Texture = "rbxassetid://1316045217"
            Particle.Rate = 5
            Particle.Lifetime = NumberRange.new(0.12, 0.24)
            Particle.Speed = NumberRange.new(0.05, 0.25)
            Particle.Color = ColorSequence.new(Theme.dark, Orb.Color)
            Particle.Size = NumberSequence.new({
                NumberSequenceKeypoint.new(0, Size * 0.18),
                NumberSequenceKeypoint.new(1, 0.02)
            })
            Particle.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0.18),
                NumberSequenceKeypoint.new(1, 0.9)
            })
            Particle.Parent = Orb

            table.insert(_G.ringParticles, {
                angle = Angle,
                part = Orb,
                speed = 0.13 + (Index % 3) * 0.018,
                height = ((Index % 2) == 0 and 0.85 or 1.15)
            })
        end
    end

    local function UpdateRingAura(Position)
        local Particles = _G.ringParticles or {}
        local Count = #Particles
        if Count <= 0 then
            return
        end

        local Radius = math.clamp(tonumber(_G.deathRingRange) or 18, 8, 600)
        local TimeNow = tick()

        for Index, Data in ipairs(Particles) do
            local Orb = Data.part
            if Orb and Orb.Parent then
                local Angle = Data.angle + TimeNow * Data.speed
                local Bob = math.sin(TimeNow * 1.7 + Index) * 0.35

                if _G.ringTheme == "Rainbow" then
                    Orb.Color = GetRainbowColor(Index / Count)
                    local Smoke = Orb:FindFirstChild("DocaRingSmoke")
                    if Smoke then
                        Smoke.Color = ColorSequence.new(Orb.Color)
                    end
                end

                Orb.Position = Vector3.new(
                    Position.X + math.cos(Angle) * Radius,
                    Position.Y - 2.8 + Data.height + Bob,
                    Position.Z + math.sin(Angle) * Radius
                )
            end
        end
    end

