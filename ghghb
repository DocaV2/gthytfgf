    local function RingHitPlayer(TargetPlayer)
        if IsRingWhitelisted(TargetPlayer) then
            return
        end

        local Character = LocalPlayerRing.Character
        local TargetCharacter = TargetPlayer and TargetPlayer.Character
        if not Character or not TargetCharacter then
            return
        end

        local TargetHumanoid = TargetCharacter:FindFirstChildOfClass("Humanoid")
        if not TargetHumanoid or TargetHumanoid.Health <= 0 then
            return
        end

        EquipPunchTool()

        local LeftHand = Character:FindFirstChild("LeftHand") or Character:FindFirstChild("Left Arm")
        local RightHand = Character:FindFirstChild("RightHand") or Character:FindFirstChild("Right Arm")

        local TargetParts = {
            TargetCharacter:FindFirstChild("HumanoidRootPart"),
            TargetCharacter:FindFirstChild("Head"),
            TargetCharacter:FindFirstChild("UpperTorso"),
            TargetCharacter:FindFirstChild("LowerTorso"),
            TargetCharacter:FindFirstChild("Torso")
        }

        for _, TargetPart in ipairs(TargetParts) do
            if TargetPart then
                TouchTarget(TargetPart, LeftHand)
                TouchTarget(TargetPart, RightHand)
            end
        end

        local PunchTool = Character:FindFirstChild("Punch")
        if PunchTool then
            pcall(function()
                PunchTool:Activate()
            end)
