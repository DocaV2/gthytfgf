                Icon = au.Mouse,
                Callback = function()
                    DocaPlayMusic(DocaFavoriteIds.Slot2)
                end
            })

            aw.UserMusic:AddButton({
                Title = "Play Slot 3",
                Content = "Play favorite sound 3.",
                Icon = au.Mouse,
                Callback = function()
                    DocaPlayMusic(DocaFavoriteIds.Slot3)
                end
            })
        end

        DocaUpdateMusicStatus()

        pcall(function()
            if as and as.OnUnload then
                as:OnUnload(function()
                    pcall(function()
                        DocaMusicSound:Stop()
                    end)
                end)
            end
