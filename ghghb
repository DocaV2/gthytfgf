        local DOCA_DAMAGE_DIVISOR = 10

        local function DocaStrengthToDamage(StrengthValue)
            -- Muscle Legends damage formula:
            -- 1.6T Strength = 160B Damage, so BaseDamage = Strength / 10.
            StrengthValue = DocaParseNumber(StrengthValue)
            return StrengthValue / DOCA_DAMAGE_DIVISOR
        end

        local function DocaGetBaseDamage(PlayerObject)
            -- Use Strength / 10 first. Some accounts have an old/rounded Damage value
            -- in leaderstats, and that can show 107B instead of the correct 160B.
            local StrengthValue = DocaParseNumber(DocaReadStat(PlayerObject, "Strength"))
            if StrengthValue and StrengthValue > 0 then
                return DocaStrengthToDamage(StrengthValue)
            end

            local DirectDamage = DocaReadFirstStat(PlayerObject, {
                "Damage",
                "damage",
                "Punch Damage",
                "PunchDamage",
                "Attack Damage",
                "AttackDamage",
                "Dmg",
