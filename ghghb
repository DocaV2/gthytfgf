        local function DocaFormatNumber(Value)
            local NumberValue = tonumber(Value)
            if not NumberValue then
                return tostring(Value or "0")
            end

            local Negative = NumberValue < 0
            NumberValue = math.abs(NumberValue)

            local Suffixes = {
                {1e30, "NO"},
                {1e27, "OC"},
                {1e24, "SP"},
                {1e21, "SX"},
                {1e18, "QI"},
                {1e15, "QA"},
                {1e12, "T"},
                {1e9, "B"},
                {1e6, "M"},
                {1e3, "K"}
            }

            for _, Data in ipairs(Suffixes) do
                local Divisor = Data[1]
                local Suffix = Data[2]
                if NumberValue >= Divisor then
                    local Text = string.format("%.2f", NumberValue / Divisor)
                    Text = Text:gsub("%.00$", ""):gsub("0$", "")
                    if Negative then
                        Text = "-" .. Text
                    end
                    return Text .. Suffix
                end
            end

            local Text = tostring(math.floor(NumberValue + 0.5))
            if Negative then
                Text = "-" .. Text
            end
            return Text
        end

        local function DocaParseNumber(Value)
            if type(Value) == "number" then
                return Value
            end

            local Text = tostring(Value or "0"):upper():gsub(",", ""):gsub("%s+", "")
            local NumberText, Suffix = Text:match("^([%-%.%d]+)(%a*)")
            local NumberValue = tonumber(NumberText) or 0

            local Multipliers = {
                K = 1e3,
                M = 1e6,
                B = 1e9,
                T = 1e12,
                QA = 1e15,
                QI = 1e18,
                SX = 1e21,
                SP = 1e24,
                OC = 1e27,
                NO = 1e30
            }

            return NumberValue * (Multipliers[Suffix] or 1)
        end

        local function DocaFormatSigned(Value)
            Value = tonumber(Value) or 0
            local Prefix = Value >= 0 and "+" or ""
            return Prefix .. DocaFormatNumber(Value)
        end

        local function DocaFormatTime(Seconds)
            Seconds = math.max(0, math.floor(tonumber(Seconds) or 0))
            local Hours = math.floor(Seconds / 3600)
            local Minutes = math.floor((Seconds % 3600) / 60)
            local Secs = Seconds % 60
            if Hours > 0 then
                return string.format("%02dh %02dm %02ds", Hours, Minutes, Secs)
            end
            return string.format("%02dm %02ds", Minutes, Secs)
        end

        local function DocaFindStatObject(PlayerObject, StatName)
            if not PlayerObject then
