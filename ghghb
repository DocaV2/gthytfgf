-- основная функция расчёта
local function fE(fF, fG, fH)
    if not fF or not fG or not fH then
        return "UNGLITCHABLE"
    end

    fF = math.floor(fF)

    if fF > fG[#fG] then
        return "UNGLITCHABLE"
    end

    local fI = fF
    local fJ = 0

    for i = 2, #fG do
        local diff = fG[i] - fG[i - 1]
        if fI >= diff then
            fI = fI - diff
            fJ = fJ + 1
        else
            break
        end
    end

    local stats = fJ * fH
    if stats == 0 then
        return "UNGLITCHABLE"
    end

    -- точное совпадение
    for i = 1, #fG do
        if fF == fG[i] then
            return i, 0, stats
        end
    end

    -- поиск следующего уровня
    local nextXP, index
    for i = 2, #fG do
        if fG[i] > fF then
            nextXP = fG[i]
            index = i
            break
        end
    end

    if not nextXP then
        return "UNGLITCHABLE"
    end

    local remain = nextXP - fF

    local level = 1
    for i = #fG, 2, -1 do
        if remain >= fG[i - 1] then
            level = i - 1
            break
        end
    end

    local xp = remain - fG[level]
    return level, xp, stats
end

function updateAllRocksParagraph()
    local result = {}
    local fG = fw[fC]
    local fH = fx[fC]

    if not fG or not fH then return end

    for _, rock in ipairs(fy) do
        local fF = (fB + 20) * rock.mult
        local lvl, xp, stats = fE(fF, fG, fH)

        if lvl == "UNGLITCHABLE" or not stats or stats == 0 then
            table.insert(result, string.format("[ %s >> UNGLITCHABLE << ]\n", rock.name))
        else
            table.insert(result, string.format(">> %s <<", rock.name))
            table.insert(result, string.format("  [Level: %d]", lvl))
            table.insert(result, string.format("  [XP: %d]", xp))
            table.insert(result, string.format(">> Stats: %d+ <<\n", stats))
        end
    end

    if #result == 0 then
        table.insert(result, "No valid rocks!")
    end

    if fD and fD.Set then
        fD:Set({
            Title = "",
            Content = table.concat(result, "\n")
        })
    end
end

