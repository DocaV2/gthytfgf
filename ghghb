            table.insert(Lines, "Durability Gain: " .. DocaFormatSigned((tonumber(DocaReadStat(DocaStatsLocalPlayer, "Durability")) or 0) - (DocaGainStart["Durability"] or 0)))
            table.insert(Lines, "Agility Gain: " .. DocaFormatSigned((tonumber(DocaReadStat(DocaStatsLocalPlayer, "Agility")) or 0) - (DocaGainStart["Agility"] or 0)))
            table.insert(Lines, "Rebirths Gain: " .. DocaFormatSigned((tonumber(DocaReadStat(DocaStatsLocalPlayer, "Rebirths")) or 0) - (DocaGainStart["Rebirths"] or 0)))
