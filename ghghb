            local NumberText = tostring(Option or "0"):match("%d+")
            return math.clamp(tonumber(NumberText) or 0, 0, 8)
        end

        local function DocaHitsToKillNumber(TargetDurability, AttackerDamage)
            TargetDurability = DocaParseNumber(TargetDurability)
            AttackerDamage = DocaParseNumber(AttackerDamage)
            if TargetDurability <= 0 or AttackerDamage <= 0 then
                return nil
            end
            return math.max(1, math.ceil(TargetDurability / AttackerDamage))
        end

        local function DocaHitsToKill(TargetDurability, AttackerDamage)
            local Hits = DocaHitsToKillNumber(TargetDurability, AttackerDamage)
            if not Hits then
