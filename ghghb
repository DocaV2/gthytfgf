        local function DocaMusicNotify(Text)
            pcall(function()
                if as and as.SetNotification then
                    as:SetNotification({"Music", "", tostring(Text or ""), nil, 0.35, 2.2})
                end
            end)
        end

        local function DocaParseSoundId(Value)
            local Text = tostring(Value or "")
            local Digits = Text:match("%d+")
            if not Digits then
                return ""
            end
            return "rbxassetid://" .. Digits
        end

        local function DocaShortSoundId(Value)
            return tostring(Value or ""):match("%d+") or "None"
        end

        local function DocaUpdateMusicStatus(Extra)
            if not DocaMusicStatus then
                return
            end

            local State = "Stopped"
            pcall(function()
                if DocaMusicSound.IsPlaying then
                    State = "Playing"
                elseif DocaCurrentSoundId ~= "" then
                    State = "Paused"
                end
            end)

            local Lines = {
                "State  : " .. State,
                "Sound  : " .. DocaShortSoundId(DocaCurrentSoundId),
                "Volume : " .. tostring(DocaMusicVolume) .. "%",
                "Speed  : " .. tostring(DocaMusicSpeed) .. "%",
                "Loop   : " .. (DocaMusicLooped and "ON" or "OFF")
            }

            if Extra and tostring(Extra) ~= "" then
                table.insert(Lines, "Info   : " .. tostring(Extra))
            end

            pcall(function()
                DocaMusicStatus:Set({
                    Title = "Local Music Player",
                    Content = table.concat(Lines, "\n")
                })
            end)
        end

        local function DocaApplyMusicSettings()
            pcall(function()
                DocaMusicSound.Volume = math.clamp((tonumber(DocaMusicVolume) or 50) / 100, 0, 1)
                DocaMusicSound.PlaybackSpeed = math.clamp((tonumber(DocaMusicSpeed) or 100) / 100, 0.5, 2)
                DocaMusicSound.Looped = DocaMusicLooped == true
            end)
        end

        local function DocaSetSoundId(Value)
            local Parsed = DocaParseSoundId(Value)
            if Parsed == "" then
                DocaCurrentSoundId = ""
                DocaMusicNotify("Enter a valid sound id")
                DocaUpdateMusicStatus("Waiting for sound id")
                return false
            end

            DocaCurrentSoundId = Parsed
            pcall(function()
                DocaMusicSound.SoundId = Parsed
            end)
            DocaApplyMusicSettings()
            DocaUpdateMusicStatus("Sound selected")
            return true
        end

        local function DocaPlayMusic(Value)
            if Value and tostring(Value) ~= "" then
                if not DocaSetSoundId(Value) then
                    return
                end
            elseif DocaCurrentSoundId == "" then
                DocaMusicNotify("Enter Sound ID first")
                DocaUpdateMusicStatus("Enter Sound ID first")
                return
            end

            DocaApplyMusicSettings()
            pcall(function()
                DocaMusicSound:Play()
            end)
            DocaUpdateMusicStatus("Playing")
        end

        local function DocaPauseMusic()
            pcall(function()
                DocaMusicSound:Pause()
            end)
            DocaUpdateMusicStatus("Paused")
