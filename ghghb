        local function DocaBuildResults(Query)
            Query = DocaLower(DocaTrim(Query))
            local Gui = DocaGetGui()
            if not Gui or not Gui.Parent then
                return {}
            end

            local Results = {}
            local Seen = {}

            if Query == "" then
                return Results
            end

            for _, Obj in ipairs(Gui:GetDescendants()) do
                if Obj:IsA("Frame") and DocaSearchItemNames[Obj.Name] and not Seen[Obj] then
                    Seen[Obj] = true

                    local Title = DocaGetMainTitle(Obj)
                    local SectionName = DocaGetSectionName(Obj)
                    local TabName = DocaGetTabName(Obj)
                    local AllText = DocaGetAllText(Obj)
                    local SearchText = DocaLower(Title .. " | " .. SectionName .. " | " .. TabName .. " | " .. AllText)

                    if SearchText:find(Query, 1, true) then
                        if Title ~= "Search Functions" and SectionName ~= "Function Search" then
                            table.insert(Results, {
                                Title = Title,
                                Section = SectionName,
                                Tab = TabName,
                                Type = Obj.Name,
                                Frame = Obj
                            })
                        end
                    end
                end
            end

            table.sort(Results, function(A, B)
                local AText = tostring(A.Tab) .. tostring(A.Section) .. tostring(A.Title)
                local BText = tostring(B.Tab) .. tostring(B.Section) .. tostring(B.Title)
                return DocaLower(AText) < DocaLower(BText)
            end)

            return Results
        end

