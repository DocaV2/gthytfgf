            DirectDamage = DocaParseNumber(DirectDamage)
            if DirectDamage and DirectDamage > 0 then
                return DirectDamage
            end

            return 0
        end

        local function DocaPackBonusPercent(Packs)
            Packs = math.clamp(tonumber(Packs) or 0, 0, 8)
            return Packs * 50 -- 1 pack = +50%, 8 packs = +400% bonus.
        end

        local function DocaPackTotalMultiplier(Packs)
            -- 1 pack = +50%; 8 packs = +400% bonus = x5 total including base.
            Packs = math.clamp(tonumber(Packs) or 0, 0, 8)
            return 1 + (Packs * 0.5)
        end

        local function DocaDamageWithPacks(BaseDamage, Packs)
            BaseDamage = tonumber(BaseDamage) or 0
            return BaseDamage * DocaPackTotalMultiplier(Packs)
        end

        local function DocaParsePackSelection(Selected)
            local Option = Selected
            if type(Selected) == "table" then
