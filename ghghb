                if Stat then
                    return Stat
                end
            end

            local Direct = PlayerObject:FindFirstChild(StatName)
            if Direct then
                return Direct
            end

            for _, FolderName in ipairs({"Stats", "stats", "PlayerStats", "playerStats", "Values", "Data"}) do
                local Folder = PlayerObject:FindFirstChild(FolderName)
                if Folder then
                    local Stat = Folder:FindFirstChild(StatName)
                    if Stat then
                        return Stat
                    end
                end
            end

            return nil
        end

        local function DocaReadStat(PlayerObject, StatName)
