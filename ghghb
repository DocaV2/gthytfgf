            local EnemyBaseDamage = DocaGetBaseDamage(PlayerObject)
            local EnemyPackedDamage = DocaDamageWithPacks(EnemyBaseDamage, Packs)
            local HitsToKillMe = DocaHitsToKill(MyDurability, EnemyPackedDamage)

            local Lines = {}
            table.insert(Lines, "Packs: " .. tostring(Packs) .. "/8  (+" .. tostring(PackBonusPercent) .. "%)")
            table.insert(Lines, "Enemy Damage " .. DocaFormatNumber(EnemyBaseDamage) .. " → " .. DocaFormatNumber(EnemyPackedDamage) .. " With Packs")
            table.insert(Lines, "He Kills You In: " .. tostring(HitsToKillMe) .. " hits")

            return table.concat(Lines, "\n")
        end

        local function DocaBuildDurabilityText(PlayerObject)
            if not PlayerObject then
                return "Player left the server."
            end

            local Packs = math.clamp(tonumber(DocaSelectedDurabilityPacks) or 0, 0, 8)
            local PackBonusPercent = DocaPackBonusPercent(Packs)
            local EnemyBaseDurability = DocaParseNumber(DocaReadStat(PlayerObject, "Durability"))
            local EnemyDurabilityWithPacks = EnemyBaseDurability * (1 + (Packs * 0.5))
            local MyBaseDamage = DocaGetBaseDamage(DocaStatsLocalPlayer)

            --// Durability calculator uses YOUR base damage against selected player's durability.
            --// Durability packs add +50% durability each: 1 pack = +50%, 8 packs = +400%.
            local BaseHitsToKillEnemy = DocaHitsToKillNumber(EnemyBaseDurability, MyBaseDamage)
            local PackedHitsToKillEnemy = DocaHitsToKillNumber(EnemyDurabilityWithPacks, MyBaseDamage)

            local Lines = {}
            table.insert(Lines, "Packs: " .. tostring(Packs) .. "/8  (+" .. tostring(PackBonusPercent) .. "% durability)")
            table.insert(Lines, "Enemy Durability " .. DocaFormatNumber(EnemyBaseDurability) .. " → " .. DocaFormatNumber(EnemyDurabilityWithPacks) .. " With Packs")

            --// Do not show ugly 1 → 1. If durability packs do not change hit count, show one clean number.
            if Packs > 0 and BaseHitsToKillEnemy and PackedHitsToKillEnemy and PackedHitsToKillEnemy > BaseHitsToKillEnemy then
                table.insert(Lines, "You Kill Him In: " .. DocaHitsText(BaseHitsToKillEnemy) .. " → " .. DocaHitsText(PackedHitsToKillEnemy) .. " hits")
            else
                table.insert(Lines, "You Kill Him In: " .. DocaHitsText(PackedHitsToKillEnemy or BaseHitsToKillEnemy) .. " hits")
            end

            return table.concat(Lines, "\n")
        end


