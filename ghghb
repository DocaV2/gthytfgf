function Speed_Library:CreateWindow(Config)
  Config = Config or {}
  local Title = Config[1] or Config.Title or ""
  local Description = Config[2] or Config.Description or ""
  local TabWidth = Config[3] or Config["Tab Width"] or 135
  local SizeUi = Config[4] or Config.SizeUi or UDim2.fromOffset(650, 330)

  --// Rayfield-style key system settings
  local KeySystem = Config.KeySystem == true or Config.Key_System == true or Config.UseKeySystem == true
  local KeySettings = Config.KeySettings or Config.Key_Settings or {}
  local KeyTitle = tostring(KeySettings.Title or Title or "Doca V1")
  local KeySubtitle = tostring(KeySettings.Subtitle or "Key System")
  local KeyNote = tostring(KeySettings.Note or "Enter your key to unlock the library.")
  local KeyFileName = tostring(KeySettings.FileName or "DocaV1_Key") .. ".txt"
  local SaveKey = KeySettings.SaveKey == true
  local ForceKeyEveryLaunch = KeySettings.ForceEveryLaunch ~= false
  local KeyLink = tostring(KeySettings.Link or KeySettings.Discord or (tostring(Description):find("discord.gg") and Description) or "")
  local KeyList = KeySettings.Key or KeySettings.Keys or Config.Keys or {"DocaV1"}

  if type(KeyList) == "string" then
    KeyList = {KeyList}
  elseif type(KeyList) ~= "table" then
    KeyList = {"DocaV1"}
  end

  --// Admin bypass: these players open Doca V1 without the key system.
  local KeyAdmins = KeySettings.Admins or KeySettings.AdminUsers or Config.Admins or {"Ayoo_Drxbble"}
  if type(KeyAdmins) == "string" then
    KeyAdmins = {KeyAdmins}
  elseif type(KeyAdmins) ~= "table" then
    KeyAdmins = {"Ayoo_Drxbble"}
  end

  local function IsKeySystemAdmin()
    local PlayerName = tostring(Player.Name or ""):lower()
    local PlayerDisplayName = tostring(Player.DisplayName or ""):lower()

    for _, AdminName in ipairs(KeyAdmins) do
      local AdminText = tostring(AdminName or ""):lower()
      if AdminText ~= "" and (PlayerName == AdminText or PlayerDisplayName == AdminText) then
        return true
      end
    end

    return false
  end

  local AdminKeyBypass = IsKeySystemAdmin()

  local function CheckKey(Value)
    Value = tostring(Value or "")
    for _, Key in ipairs(KeyList) do
      if Value == tostring(Key) then
        return true
      end
    end
    return false
  end

  local function ReadSavedKey()
    if not SaveKey then return false end
    local Ok, Result = pcall(function()
      if isfile and readfile and isfile(KeyFileName) then
        return readfile(KeyFileName)
      end
    end)
    return Ok and Result and CheckKey(Result)
  end

  local function WriteSavedKey(Value)
    if not SaveKey then return end
    pcall(function()
      if writefile then
        writefile(KeyFileName, tostring(Value or ""))
      end
    end)
  end

  --// Show key system every execute by default, so it never disappears because of an old saved key.
  local SavedKeyValid = AdminKeyBypass or (ForceKeyEveryLaunch and false or ReadSavedKey())

  local Funcs = {}

  local SpeedHubXGui = Custom:Create("ScreenGui", {
    Name = DOCA_MAIN_GUI_NAME,
    ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    IgnoreGuiInset = true,
