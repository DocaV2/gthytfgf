--// Doca V1 hard runtime cleanup
--// Fixes stuck old Auto Kill / Auto Kill In Part / Ring Aura after re-execute.
local function DocaHardRuntimeCleanup()
  pcall(function()
    _G.DocaV1_AutoKillActive = false

    if _G.DocaV1_AutoKillConnections then
      for _, Connection in pairs(_G.DocaV1_AutoKillConnections) do
        pcall(function()
          if Connection and Connection.Disconnect then
            Connection:Disconnect()
          end
        end)
      end
    end
    _G.DocaV1_AutoKillConnections = {}

    if _G.DocaV1_AutoKillReturnCFrame and Player.Character then
      local Root = Player.Character:FindFirstChild("HumanoidRootPart")
      if Root then
        Root.CFrame = _G.DocaV1_AutoKillReturnCFrame
        Root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        Root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        Root.Velocity = Vector3.new(0, 0, 0)
        Root.RotVelocity = Vector3.new(0, 0, 0)
      end
    end
    _G.DocaV1_AutoKillReturnCFrame = nil

    local OldPart = workspace:FindFirstChild("DocaV1_AutoKillInPart")
    if OldPart then
      OldPart:Destroy()
    end

    _G.showDeathRing = false
    if _G.visualizerConnection then
      _G.visualizerConnection:Disconnect()
      _G.visualizerConnection = nil
    end
    if _G.deathRingFolder then
      _G.deathRingFolder:Destroy()
      _G.deathRingFolder = nil
    end
    local OldRing = workspace:FindFirstChild("DeathRingVisualizer")
    if OldRing then
      OldRing:Destroy()
    end
    _G.ringParticles = {}
  end)

  --// Extra old-connection debug scan disabled in NoLag edition.
  --// The old getconnections/debug.getupvalue scan was heavy after obfuscation.
  --// Current cleanup above still removes DocaV1 globals, parts and visual folders safely.
end

