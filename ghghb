                if Ok and Value ~= nil then
                    return Value
                end
            end

            local OkAttribute, AttributeValue = pcall(function()
                return PlayerObject and PlayerObject:GetAttribute(StatName)
            end)
            if OkAttribute and AttributeValue ~= nil then
                return AttributeValue
            end

            return 0
        end

