                if Found then
                    return Found
                end
            end
            return nil
        end

        local function DocaIsAlive(Object)
            return Object ~= nil and Object.Parent ~= nil
        end

        local function DocaSetAttribute(Object, Name, Value)
            pcall(function()
                Object:SetAttribute(Name, Value)
            end)
        end

        local function DocaHasAttribute(Object, Name)
            local Ok, Value = pcall(function()
                return Object:GetAttribute(Name)
            end)
            return Ok and Value == true
        end

        local function DocaIsOldAccent(Color)
            if typeof(Color) ~= "Color3" then
                return false
            end
            local R, G, B = Color.R, Color.G, Color.B
            return R > 0.42 and R > (G * 1.18) and R > (B * 1.05)
        end

        local function DocaBrightness(Color)
            return (Color.R * 0.299) + (Color.G * 0.587) + (Color.B * 0.114)
        end

        local function DocaReadableColor()
            if DocaBrightness(DocaCurrentAccent) >= 0.62 then
                return Color3.fromRGB(18, 18, 22)
            end
            return Color3.fromRGB(255, 255, 255)
        end

        local function DocaAccentDark(Amount)
            Amount = tonumber(Amount) or 0.55
            return DocaCurrentAccent:Lerp(Color3.fromRGB(15, 15, 15), math.clamp(Amount, 0, 1))
        end

        local function DocaAccentLight(Amount)
            Amount = tonumber(Amount) or 0.25
            return DocaCurrentAccent:Lerp(Color3.fromRGB(255, 255, 255), math.clamp(Amount, 0, 1))
        end

        local function DocaIsCardName(Name)
            Name = tostring(Name or ""):lower()
            return Name:find("button") ~= nil
                or Name:find("toggle") ~= nil
                or Name:find("slider") ~= nil
                or Name:find("input") ~= nil
                or Name:find("dropdown") ~= nil
                or Name:find("paragraph") ~= nil
        end

        local function DocaIsLineObject(Object)
            if not Object then return false end
            local Name = tostring(Object.Name or ""):lower()
            local ParentName = Object.Parent and tostring(Object.Parent.Name or ""):lower() or ""
            local GrandName = Object.Parent and Object.Parent.Parent and tostring(Object.Parent.Parent.Name or ""):lower() or ""
            return Name:find("separator") ~= nil
                or Name:find("keytopline") ~= nil
                or Name:find("lineshine") ~= nil
                or Name:find("linebar") ~= nil
                or ParentName:find("separator") ~= nil
                or ParentName:find("keytopline") ~= nil
                or ParentName:find("lineshine") ~= nil
                or ParentName:find("linebar") ~= nil
                or GrandName:find("separator") ~= nil
                or GrandName:find("keytopline") ~= nil
        end

        local function DocaAddCached(List, Object, Seen)
            if Object and not Seen[Object] then
                Seen[Object] = true
                table.insert(List, Object)
            end
        end

        local function DocaRebuildStyleCache()
            local Gui = DocaGetMainGui()
            if not Gui then
                return false
            end

            DocaStyleCache.Gui = Gui
            DocaStyleCache.Built = true
            DocaStyleCache.BallsHolder = nil

            DocaClearTable(DocaStyleCache.AccentBG)
            DocaClearTable(DocaStyleCache.AccentText)
            DocaClearTable(DocaStyleCache.AccentImage)
            DocaClearTable(DocaStyleCache.AccentStroke)
            DocaClearTable(DocaStyleCache.LineObjects)
            DocaClearTable(DocaStyleCache.LineGradients)
            DocaClearTable(DocaStyleCache.ToggleTracks)
            DocaClearTable(DocaStyleCache.ToggleKnobs)
            DocaClearTable(DocaStyleCache.ToggleStrokes)
            DocaClearTable(DocaStyleCache.Cards)
            DocaClearTable(DocaStyleCache.MainFrames)
            DocaClearTable(DocaStyleCache.Balls)

            local Seen = {}

            for _, Object in ipairs(Gui:GetDescendants()) do
                local Name = tostring(Object.Name or ""):lower()
                local Parent = Object.Parent
                local ParentName = Parent and tostring(Parent.Name or ""):lower() or ""

                if Object:IsA("Frame") then
                    if Name == "main" then
                        DocaAddCached(DocaStyleCache.MainFrames, Object, Seen)
                    end

                    if DocaIsCardName(Name) then
                        DocaAddCached(DocaStyleCache.Cards, Object, Seen)
                    end

                    if Name == "floatingballs" then
                        DocaStyleCache.BallsHolder = Object
                    elseif Name:find("floatingball") then
                        DocaAddCached(DocaStyleCache.Balls, Object, Seen)
                    end

                    if Name == "featureframe2" then
                        DocaSetAttribute(Object, "DocaV1ToggleTrack", true)
                        DocaAddCached(DocaStyleCache.ToggleTracks, Object, Seen)
                    elseif Name == "togglecircle" and ParentName == "featureframe2" then
                        DocaSetAttribute(Object, "DocaV1ToggleKnob", true)
                        DocaAddCached(DocaStyleCache.ToggleKnobs, Object, Seen)
                    end

                    if DocaIsLineObject(Object) then
                        DocaSetAttribute(Object, "DocaV1LineBar", true)
                        DocaAddCached(DocaStyleCache.LineObjects, Object, Seen)
                    end

                    if DocaHasAttribute(Object, "DocaV1AccentBG") or DocaIsOldAccent(Object.BackgroundColor3) then
                        DocaSetAttribute(Object, "DocaV1AccentBG", true)
                        DocaAddCached(DocaStyleCache.AccentBG, Object, Seen)
                    end
                elseif Object:IsA("TextLabel") or Object:IsA("TextButton") or Object:IsA("TextBox") then
                    if DocaHasAttribute(Object, "DocaV1AccentText") or DocaIsOldAccent(Object.TextColor3) then
                        DocaSetAttribute(Object, "DocaV1AccentText", true)
                        DocaAddCached(DocaStyleCache.AccentText, Object, Seen)
                    end
                elseif Object:IsA("ImageLabel") or Object:IsA("ImageButton") then
                    if Name:find("floatingball") then
                        DocaAddCached(DocaStyleCache.Balls, Object, Seen)
                    end
                    if DocaHasAttribute(Object, "DocaV1AccentImage") or DocaIsOldAccent(Object.ImageColor3) then
                        DocaSetAttribute(Object, "DocaV1AccentImage", true)
                        DocaAddCached(DocaStyleCache.AccentImage, Object, Seen)
                    end
                elseif Object:IsA("UIStroke") then
                    if ParentName == "featureframe2" then
                        DocaSetAttribute(Object, "DocaV1ToggleStroke", true)
                        DocaAddCached(DocaStyleCache.ToggleStrokes, Object, Seen)
                    elseif DocaHasAttribute(Object, "DocaV1AccentStroke") or DocaIsOldAccent(Object.Color) then
                        DocaSetAttribute(Object, "DocaV1AccentStroke", true)
                        DocaAddCached(DocaStyleCache.AccentStroke, Object, Seen)
                    end
                elseif Object:IsA("UIGradient") then
                    if DocaIsLineObject(Object) then
                        DocaSetAttribute(Object, "DocaV1LineBar", true)
                        DocaAddCached(DocaStyleCache.LineGradients, Object, Seen)
                    end
                end
            end

            return true
        end

        local function DocaPaintLineObject(Object)
            if not DocaIsAlive(Object) then return end
            pcall(function()
                local Name = tostring(Object.Name or ""):lower()
                if Object:IsA("Frame") then
                    Object.Visible = DocaLineVisible
                    Object.BackgroundColor3 = DocaCurrentAccent
                    if Name:find("glow") then
                        Object.BackgroundTransparency = 0.82
                    elseif Name:find("core") then
                        Object.BackgroundTransparency = 0.05
                    elseif Name:find("spark") then
                        Object.BackgroundTransparency = 0.04
                    end
                elseif Object:IsA("ImageLabel") or Object:IsA("ImageButton") then
                    Object.Visible = DocaLineVisible
                    Object.ImageColor3 = DocaCurrentAccent
                end
            end)
        end

        local function DocaPaintLineGradient(Gradient)
            if not DocaIsAlive(Gradient) then return end
            pcall(function()
                Gradient.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(15, 15, 15)),
                    ColorSequenceKeypoint.new(0.2, DocaAccentDark(0.35)),
                    ColorSequenceKeypoint.new(0.5, DocaAccentLight(0.18)),
                    ColorSequenceKeypoint.new(0.8, DocaAccentDark(0.35)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(15, 15, 15))
                })
            end)
        end

        local function DocaIsToggleOnTrack(Track)
            if not Track then
                return false
            end

            local Ok, Value = pcall(function()
                return Track:GetAttribute("DocaV1ToggleOn")
            end)

            if Ok and Value ~= nil then
                return Value == true
            end

            local Knob = Track:FindFirstChild("ToggleCircle")
            if Knob and Knob:IsA("GuiObject") then
                return Knob.Position.X.Scale > 0.5 or Knob.Position.X.Offset > 8
            end

            return false
        end

        local function DocaApplyToggleContrast()
            local Readable = DocaReadableColor()

            for _, Track in ipairs(DocaStyleCache.ToggleTracks) do
                if DocaIsAlive(Track) then
                    pcall(function()
                        local IsOn = DocaIsToggleOnTrack(Track)
                        if IsOn then
                            Track.BackgroundColor3 = DocaCurrentAccent
                            Track.BackgroundTransparency = 0
                        else
                            Track.BackgroundColor3 = Color3.fromRGB(46, 46, 52)
                            Track.BackgroundTransparency = 0
                        end
                        Track.Size = UDim2.new(0, 32, 0, 16)
                    end)
                end
            end

            for _, Knob in ipairs(DocaStyleCache.ToggleKnobs) do
                if DocaIsAlive(Knob) then
                    pcall(function()
                        local Track = Knob.Parent
                        local IsOn = Track and DocaIsToggleOnTrack(Track)
                        Knob.AnchorPoint = Vector2.new(0, 0.5)
                        Knob.Size = UDim2.new(0, 12, 0, 12)
                        Knob.Position = IsOn and UDim2.new(1, -14, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
                        Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                        Knob.BackgroundTransparency = 0
                        Knob.ZIndex = math.max(Knob.ZIndex, ((Track and Track.ZIndex) or 1) + 2)
                        local KnobStroke = Knob:FindFirstChildOfClass("UIStroke")
                        if KnobStroke then
                            KnobStroke.Color = Color3.fromRGB(20, 20, 24)
                            KnobStroke.Transparency = 0.18
                            KnobStroke.Thickness = 0.85
                        end
                    end)
                end
            end

            for _, Stroke in ipairs(DocaStyleCache.ToggleStrokes) do
                if DocaIsAlive(Stroke) then
                    pcall(function()
                        local Track = Stroke.Parent
                        local IsOn = Track and DocaIsToggleOnTrack(Track)
                        if IsOn then
                            Stroke.Color = Color3.fromRGB(255, 255, 255)
                            Stroke.Transparency = 0.36
                            Stroke.Thickness = 1
                        else
                            Stroke.Color = Color3.fromRGB(255, 255, 255)
                            Stroke.Transparency = 0.56
                            Stroke.Thickness = 1
                        end
                    end)
                end
            end
        end

        local function DocaUpdateStyleStatus(Force)
            local Now = tick()
            if not Force and (Now - DocaLastStatusUpdate) < 1.5 then
                return
            end
            DocaLastStatusUpdate = Now

            if DocaStyleStatus then
                local Lines = {
                    "Accent: RGB(" .. tostring(math.floor(DocaCurrentAccent.R * 255)) .. ", " .. tostring(math.floor(DocaCurrentAccent.G * 255)) .. ", " .. tostring(math.floor(DocaCurrentAccent.B * 255)) .. ")",
                    "Window Transparency: " .. tostring(DocaWindowTransparency) .. "%",
