          local NewTitle = Config[1] or Config.Title or Title
          local NewContent = Config[2] or Config.Content or ""

          ParagraphTitle.Text = NewTitle
          ParagraphContent.Text = NewContent

          UpdateParagraphSize()
        end

        return SettingFuncs
      end

