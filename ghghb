    local function DocaFormatRebirthTime(Seconds)
        Seconds = math.max(0, math.floor(tonumber(Seconds) or 0))
        local Hours = math.floor(Seconds / 3600)
        local Minutes = math.floor((Seconds % 3600) / 60)
        local Secs = Seconds % 60
        if Hours > 0 then
            return string.format("%02dh %02dm %02ds", Hours, Minutes, Secs)
        end
        return string.format("%02dm %02ds", Minutes, Secs)
    end

    local function DocaFormatRebirthNumber(Value)
        Value = tonumber(Value) or 0
        local Negative = Value < 0
        Value = math.abs(Value)

        local function Trim(Text)
            Text = tostring(Text)
            Text = Text:gsub("%.0$", "")
            return (Negative and "-" or "") .. Text
        end

        local function Short(Divisor, Suffix)
            --// Truncates instead of rounding, so 98999 will not become 99.0k.
            local ShortValue = math.floor((Value / Divisor) * 10) / 10
            return Trim(string.format("%.1f", ShortValue)) .. Suffix
        end

        if Value >= 1e15 then
            return Short(1e15, "qi")
        elseif Value >= 1e12 then
            return Short(1e12, "t")
        elseif Value >= 1e9 then
            return Short(1e9, "b")
        elseif Value >= 1e6 then
            return Short(1e6, "m")
        elseif Value >= 1e3 then
            return Short(1e3, "k")
        end

        return (Negative and "-" or "") .. tostring(math.floor(Value))
    end

    local function DocaBuildRebirthForecast(PerSecond)
        PerSecond = tonumber(PerSecond) or 0
        return "1 Minute : " .. DocaFormatRebirthNumber(PerSecond * 60) .. "\n" ..
               "1 Hour   : " .. DocaFormatRebirthNumber(PerSecond * 3600) .. "\n" ..
               "1 Day    : " .. DocaFormatRebirthNumber(PerSecond * 86400) .. "\n" ..
               "7 Days   : " .. DocaFormatRebirthNumber(PerSecond * 86400 * 7) .. "\n" ..
               "30 Days  : " .. DocaFormatRebirthNumber(PerSecond * 86400 * 30)
    end

    local function DocaUpdateRebirthCounter()
        local Now = tick()
        local Current = tonumber(Q.Value) or 0
        local DeltaTime = math.clamp(Now - (DocaRebirthLastTick or Now), 0, 5)
        local LastGain = math.max(0, Current - (DocaRebirthLastValue or Current))

        if Current > DocaRebirthLastValue then
            DocaRebirthIsFarming = true
            DocaRebirthLastGainTick = Now
        elseif (Now - DocaRebirthLastGainTick) > DocaRebirthIdleTimeout then
            DocaRebirthIsFarming = false
        end

        if DocaRebirthIsFarming and DeltaTime > 0 then
            DocaRebirthActiveSeconds = DocaRebirthActiveSeconds + DeltaTime
        end

        DocaRebirthLastValue = Current
        DocaRebirthLastTick = Now

        local PerSecond = 0
        if DocaRebirthActiveSeconds > 0 then
            local TotalGain = math.max(0, Current - (DocaRebirthStartValue or Current))
            PerSecond = TotalGain / math.max(DocaRebirthActiveSeconds, 1)
        end

        local Text = "Current Rebirths : " .. DocaFormatRebirthNumber(Current) .. "\n" ..
                     "Last Gain        : +" .. DocaFormatRebirthNumber(LastGain) .. "\n" ..
                     "Status           : " .. (DocaRebirthIsFarming and "FARMING" or "PAUSED") .. "\n" ..
                     "Active Time      : " .. DocaFormatRebirthTime(DocaRebirthActiveSeconds) .. "\n" ..
                     "Last Gain Ago    : " .. DocaFormatRebirthTime(Now - DocaRebirthLastGainTick) .. "\n\n" ..
                     "Forecast:\n" .. DocaBuildRebirthForecast(PerSecond)

        pcall(function()
            DocaRebirthStatsParagraph:Set({
                Title = "Rebirth Counter",
                Content = Text
            })
        end)
    end

